  "keyFeatures": [
    "Compile HuggingFace transformers to native Metal binaries",
    "1.35x faster with 25% less GPU power than mlx-lm",
    "Multiple quantization levels (F16, Q8_0, Q4_0)",
    "JIT (.unc bundle) and AOT (standalone binary) modes",
    "Hardware-agnostic IR with Metal backend (CUDA/ROCm/WASM planned)",
    "Advanced compiler passes: fusion, quantization, memory planning",
    "Zero Python runtime overhead - pure native execution",
    "Support for LLaMA, Mistral, Qwen, Phi, Gemma architectures"
  ],
  "publicApiSurface": [
